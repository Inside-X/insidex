# Copy this file to .env and set real values locally or via secret manager
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@localhost:5432/insidex?schema=public&connection_limit=10&pool_timeout=20&connect_timeout=10&sslmode=prefer"
DATABASE_SSL_MODE="prefer"

# Runtime mode / logging
NODE_ENV="development"            # development | test | production
LOG_LEVEL="debug"                 # debug | info | warn | error
LOG_FORMAT="json"                 # json | pretty (pretty is non-prod convenience)

# JWT access token settings
JWT_ACCESS_SECRET="replace-with-a-strong-random-secret-min-32-chars"
JWT_ACCESS_ISSUER="insidex-auth"
JWT_ACCESS_AUDIENCE="insidex-api"
JWT_ACCESS_EXPIRY="15m"

# JWT refresh token settings
JWT_REFRESH_SECRET="replace-with-a-different-strong-random-secret-min-32-chars"
JWT_REFRESH_ISSUER="insidex-auth-refresh"
JWT_REFRESH_AUDIENCE="insidex-api-refresh"
JWT_REFRESH_EXPIRY="30m"

# Legacy/shared JWT secret (still required by current boot validation)
JWT_SECRET="replace-with-a-strong-random-secret-min-32-chars"

# CORS whitelist (comma-separated origins)
# Example: CORS_ORIGIN="https://app.insidex.com,https://admin.insidex.com"
CORS_ORIGIN="http://localhost:3000"

# Infrastructure
REDIS_URL="redis://127.0.0.1:6379"

# Payments toggles
PAYMENTS_ENABLED="false"          # true | false
PAYMENTS_PROVIDER="stripe"        # stripe | paypal | both

# Stripe (required in production when PAYMENTS_ENABLED=true and provider includes stripe)
STRIPE_SECRET="sk_test_replace_me"
PAYMENT_WEBHOOK_SECRET="whsec_replace_me"

# PayPal (required in production when PAYMENTS_ENABLED=true and provider includes paypal)
PAYPAL_CLIENT_ID="replace-me"
PAYPAL_SECRET="replace-me"
PAYPAL_WEBHOOK_ID="replace-me"
PAYPAL_API_BASE_URL="https://api-m.sandbox.paypal.com"

# Webhook idempotency behavior
# production always runs strict mode; non-prod can force strict behavior by setting true
WEBHOOK_IDEMPOTENCY_STRICT="false"
# test-only escape hatch; do not enable in production
WEBHOOK_IDEMPOTENCY_ALLOW_TEST_FALLBACK="false"