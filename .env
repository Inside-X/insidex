# PostgreSQL connection string for Prisma (do not commit real secrets)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public&connection_limit=10&pool_timeout=20&connect_timeout=10&sslmode=prefer

# Toggle SSL mode depending on environment: disable | prefer | require | verify-ca | verify-full
# For production managed DB, prefer require/verify-full
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/insidex_clean?schema=public"
DATABASE_SSL_MODE="prefer"
REDIS_URL="redis://127.0.0.1:6379"