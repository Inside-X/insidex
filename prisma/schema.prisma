generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  customer
}

enum OrderStatus {
  pending
  paid
  shipped
  cancelled
}

enum ProductStatus {
  draft
  published
  active
  archived
}

enum ProductImageKind {
  image
}

enum StockStatus {
  in_stock
  low_stock
  out_of_stock
  unknown
}

model User {
  id              String           @id @default(uuid()) @db.Uuid
  email           String           @unique @db.VarChar(320)
  passwordHash    String?          @map("password_hash")
  role            Role             @default(customer)
  isGuest         Boolean          @default(false) @map("is_guest")
  guestAddress    Json             @default("{}") @map("guest_address") @db.JsonB
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  cart            Cart?
  orders          Order[]
  analyticsEvents AnalyticsEvent[]

  @@index([email], map: "idx_users_email")
  @@index([isGuest], map: "idx_users_is_guest")
  @@map("users")
}

model Product {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(255)
  name            String           @db.VarChar(255)
  description     String?
  shortDescription String?         @map("short_description")
  status          ProductStatus    @default(draft)
  price           Decimal          @db.Decimal(12, 2)
  currency        String           @default("EUR") @db.VarChar(3)
  stock           Int
  stockStatus     StockStatus      @default(in_stock) @map("stock_status")
  stockQuantity   Int?             @map("stock_quantity")
  backorderable   Boolean          @default(false)
  localDeliveryEnabled Boolean     @default(false) @map("local_delivery_enabled")
  active          Boolean          @default(true)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  cartItems       CartItem[]
  orderItems      OrderItem[]
  images          ProductImage[]
  variants        ProductVariant[]
  specs           ProductSpec[]

  @@index([active, createdAt], map: "idx_products_active_created_at")
  @@index([name], map: "idx_products_name")
  @@index([slug], map: "idx_products_slug")
  @@index([status], map: "idx_products_status")
  @@index([stockStatus], map: "idx_products_stock_status")
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  url       String
  alt       String   @db.VarChar(255)
  width     Int?
  height    Int?
  isPrimary Boolean          @default(false) @map("is_primary")
  kind      ProductImageKind @default(image)
  position  Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, position], map: "uq_product_images_product_position")
  @@index([productId], map: "idx_product_images_product_id")
  @@map("product_images")
}

model ProductVariant {
  id            String      @id @default(uuid()) @db.Uuid
  productId     String      @map("product_id") @db.Uuid
  sku           String      @unique @db.VarChar(120)
  label         String      @db.VarChar(255)
  attributes    Json        @default("{}") @db.JsonB
  priceDelta    Decimal?    @map("price_delta") @db.Decimal(12, 2)
  absolutePrice Decimal?    @map("absolute_price") @db.Decimal(12, 2)
  stockStatus   StockStatus @default(in_stock) @map("stock_status")
  stockQuantity Int?        @map("stock_quantity")
  backorderable Boolean     @default(false)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([sku], map: "idx_product_variants_sku")
  @@index([productId], map: "idx_product_variants_product_id")
  @@index([stockStatus], map: "idx_product_variants_stock_status")
  @@map("product_variants")
}

model ProductSpec {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  key       String   @db.VarChar(120)
  value     String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key], map: "uq_product_specs_product_key")
  @@index([productId, position], map: "idx_product_specs_product_position")
  @@map("product_specs")
}

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @unique @map("user_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@index([userId], map: "idx_carts_user_id")
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId], map: "uq_cart_items_cart_product")
  @@index([cartId], map: "idx_cart_items_cart_id")
  @@index([productId], map: "idx_cart_items_product_id")
  @@map("cart_items")
}

model Order {
  id                    String      @id @default(uuid()) @db.Uuid
  userId                String      @map("user_id") @db.Uuid
  idempotencyKey        String      @map("idempotency_key") @db.VarChar(128)
  stripePaymentIntentId String?     @unique @map("stripe_payment_intent_id") @db.VarChar(255)
  status                OrderStatus @default(pending)
  fulfillmentMode       String      @map("fulfillment_mode") @db.VarChar(40)
  fulfillmentSnapshot   Json        @map("fulfillment_snapshot") @db.JsonB
  totalAmount           Decimal     @map("total_amount") @db.Decimal(12, 2)
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  items                 OrderItem[]

  webhookEvents PaymentWebhookEvent[]
  events        OrderEvent[]

  @@index([userId, createdAt], map: "idx_orders_user_created_at")
  @@index([status, createdAt], map: "idx_orders_status_created_at")
  @@unique([userId, idempotencyKey], map: "uq_orders_user_idempotency")
  @@map("orders")
}

model PaymentWebhookEvent {
  id        String   @id @default(uuid()) @db.Uuid
  provider  String   @db.VarChar(40)
  eventId   String   @map("event_id") @db.VarChar(255)
  resourceId String? @map("resource_id") @db.VarChar(255)
  orderId   String?  @map("order_id") @db.Uuid
  payload   Json     @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId], map: "uq_payment_webhook_events_provider_event")
  @@unique([provider, resourceId], map: "uq_payment_webhook_events_provider_resource")
  @@index([provider, createdAt], map: "idx_payment_webhook_events_provider_created_at")
  @@index([orderId], map: "idx_payment_webhook_events_order_id")
  @@map("payment_webhook_events")
}


model OrderEvent {
  id             String      @id @default(uuid()) @db.Uuid
  orderId        String      @map("order_id") @db.Uuid
  type           String      @db.VarChar(64)
  fromStatus     OrderStatus @map("from_status")
  toStatus       OrderStatus @map("to_status")
  source         String      @db.VarChar(20)
  sourceEventId  String?     @map("source_event_id") @db.VarChar(255)
  idempotencyKey String?     @map("idempotency_key") @db.VarChar(128)
  correlationId  String?     @map("correlation_id") @db.VarChar(128)
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt], map: "idx_order_events_order_created_at")
  @@unique([orderId, source, sourceEventId], map: "uq_order_events_order_source_event")
  @@map("order_events")
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([orderId, productId], map: "uq_order_items_order_product")
  @@index([orderId], map: "idx_order_items_order_id")
  @@index([productId], map: "idx_order_items_product_id")
  @@map("order_items")
}

model MediaUploadSession {
  id              String                          @id @db.VarChar(64)
  filename        String                          @db.VarChar(255)
  mimeType        String                          @map("mime_type") @db.VarChar(64)
  sizeBytes       Int                             @map("size_bytes")
  sha256          String?                         @db.VarChar(128)
  uploadUrl       String                          @map("upload_url")
  expiresAt       DateTime                        @map("expires_at") @db.Timestamptz(6)
  finalizedAt     DateTime?                       @map("finalized_at") @db.Timestamptz(6)
  createdAt       DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                        @updatedAt @map("updated_at") @db.Timestamptz(6)
  assets          MediaUploadedAsset[]
  finalizeRecords MediaUploadFinalizeIdempotency[]

  @@index([expiresAt], map: "idx_media_upload_sessions_expires_at")
  @@map("media_upload_sessions")
}

model MediaUploadedAsset {
  id                String                          @id @default(uuid()) @db.Uuid
  uploadId          String                          @map("upload_id") @db.VarChar(64)
  providerAssetId   String                          @map("provider_asset_id") @db.VarChar(128)
  url               String
  mimeType          String                          @map("mime_type") @db.VarChar(64)
  sizeBytes         Int                             @map("size_bytes")
  width             Int
  height            Int
  checksumSha256    String                          @map("checksum_sha256") @db.VarChar(128)
  assetCreatedAt    DateTime                        @map("asset_created_at") @db.Timestamptz(6)
  createdAt         DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  uploadSession     MediaUploadSession              @relation(fields: [uploadId], references: [id], onDelete: Restrict)
  finalizeIdempotencyRecords MediaUploadFinalizeIdempotency[]

  @@index([uploadId], map: "idx_media_uploaded_assets_upload_id")
  @@unique([uploadId, providerAssetId], map: "uq_media_uploaded_assets_upload_provider_asset")
  @@map("media_uploaded_assets")
}

model MediaUploadFinalizeIdempotency {
  id             String             @id @default(uuid()) @db.Uuid
  uploadId       String             @map("upload_id") @db.VarChar(64)
  idempotencyKey String             @map("idempotency_key") @db.VarChar(128)
  assetId        String             @map("asset_id") @db.Uuid
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  uploadSession  MediaUploadSession @relation(fields: [uploadId], references: [id], onDelete: Restrict)
  asset          MediaUploadedAsset @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([uploadId, idempotencyKey], map: "uq_media_upload_finalize_upload_idempotency")
  @@index([assetId], map: "idx_media_upload_finalize_asset_id")
  @@map("media_upload_finalize_idempotency")
}

model Lead {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(320)
  message   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt], map: "idx_leads_created_at")
  @@index([email], map: "idx_leads_email")
  @@map("leads")
}

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventType String   @map("event_type") @db.VarChar(100)
  userId    String?  @map("user_id") @db.Uuid
  payload   Json     @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt], map: "idx_analytics_events_type_created_at")
  @@index([userId, createdAt], map: "idx_analytics_events_user_created_at")
  @@map("analytics_events")
}
